# Copy to .env and fill in values. Never commit .env.

# --- Required ---
OPENAI_API_KEY=

# --- OpenAI (optional; required only for org/project-scoped keys) ---
OPENAI_ORGANIZATION_ID=
OPENAI_PROJECT_ID=

# --- Models (optional; defaults documented in README) ---
# Defaults if unset: SUMMARY_MODEL=gpt-4o-mini, RANK_MODEL=gpt-4o-mini
SUMMARY_MODEL=
RANK_MODEL=

# --- Cost / volume tuning (optional) ---
# Cap how many collected articles get summarized (omit = no cap).
SUMMARIZE_MAX_ARTICLES=
# How many stories to rank and output (CLI --top-n overrides).
TOP_ARTICLES=10

# --- Date filtering (optional; default off) ---
# When true, keeps only articles whose published timestamp falls on the pipeline date (UTC).
# CLI: --filter-by-date
ARTICLE_DATE_FILTER=false
# When date filtering is on: keep articles whose publication date could not be parsed (default true).
DATE_FILTER_KEEP_UNKNOWN=true

# --- Notion (optional unless --output notion / daily_scheduler) ---
NOTION_TOKEN=
NOTION_DATABASE_ID=

# --- Slack (optional; daily_scheduler posts here when configured) ---
# Preferred name (legacy SLACK_WEBHOOK also accepted):
SLACK_WEBHOOK_URL=

# --- Pushover (optional; iPhone notifications from daily_scheduler) ---
PUSHOVER_TOKEN=
# User key (alias: PUSHOVER_USER_KEY):
PUSHOVER_USER=

# --- Email (optional; --output email) ---
SMTP_SERVER=
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
RECIPIENT_EMAIL=

# --- Logging ---
LOG_LEVEL=INFO
# Rotating file handler is default (10 MiB x 5 backups). Disable with LOG_DISABLE_ROTATE=true.
# LOG_FILE_PATH=ai_news_agent.log
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5
# LOG_DISABLE_ROTATE=false

# --- Cross-run dedupe (same stories staying in RSS feeds for days) ---
# Persists URLs, outlet-normalized titles, URL slug keys, and core title keys.
# Recording runs only after a successful digest output (see README).
CROSS_RUN_DEDUPE=true
# digest (default): remember only ranked top N shipped in the digest.
# summarized: legacy — remember every summarized row (can skip all candidates once feeds repeat).
# SEEN_RECORD_SCOPE=digest
SEEN_ARTICLES_PATH=data/seen_articles.json
# Relative paths resolve from the repo root (folder containing seen_articles.py), not the shell cwd.
URL_COOLDOWN_DAYS=120
TITLE_COOLDOWN_DAYS=90
# SLUG_COOLDOWN_DAYS=   # default = URL_COOLDOWN_DAYS
# CORE_TITLE_COOLDOWN_DAYS=   # default = TITLE_COOLDOWN_DAYS
SEEN_STORE_RETENTION_DAYS=548

# --- Fetch performance (optional) ---
# Parallel fetch across sources (default true). Set false if a provider rate-limits you.
FETCH_PARALLEL=true
FETCH_MAX_WORKERS=8

# --- Richer excerpts for summarization (optional; extra HTTP per thin article) ---
# Fetches article HTML when RSS/snippet text is shorter than ENRICH_MIN_PLAINTEXT_CHARS.
ENRICH_ARTICLE_HTML=false
ENRICH_MAX_PER_RUN=12
ENRICH_MIN_PLAINTEXT_CHARS=360
ENRICH_MAX_PLAINTEXT_CHARS=12000
ENRICH_MAX_RESPONSE_BYTES=800000
